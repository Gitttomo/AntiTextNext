# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Get these values from your Supabase project settings:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project (or create a new one)
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key below

NEXT_PUBLIC_SUPABASE_URL=https://your-actual-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-actual-long-key
# Example:
# NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only. Used by /api/books/isbn as a Google Books fallback.
# Do not expose this as NEXT_PUBLIC unless you intentionally want it in the browser bundle.
GOOGLE_BOOKS_API_KEY=your-google-books-api-key
