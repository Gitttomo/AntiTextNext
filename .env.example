# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Get these values from your Supabase project settings:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project (or create a new one)
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key below

NEXT_PUBLIC_SUPABASE_URL=https://your-actual-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-actual-long-key
# Example:
# NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only. Used by /api/books/isbn as a Google Books fallback.
# Do not expose this as NEXT_PUBLIC unless you intentionally want it in the browser bundle.
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Cloudflare R2
# Server-side only. Never expose access keys or secret keys as NEXT_PUBLIC_*.
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://img.textnext.jp
# R2_ENDPOINT=

# Public display-only URL base for client-side image URL construction.
# This is not a secret. Keep it equal to R2_PUBLIC_BASE_URL unless you intentionally use another public domain.
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://img.textnext.jp

# Admin protection
# Server-side only. Used by middleware for /admin Basic authentication.
# ADMIN_BASIC_USER=
# ADMIN_BASIC_PASSWORD=

# Stripe
# Server-side only. Never expose Stripe secret keys as NEXT_PUBLIC_*.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
